# =============================================================================
# CoachingOS Monorepo GitIgnore
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 1. Dependency Directories
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
jspm_packages/
web_modules/

# Python Virtual Environments
venv/
.venv/
env/
ENV/
*.pyc
__pycache__/

# ─────────────────────────────────────────────────────────────────────────────
# 2. Build & Cache Artifacts
# ─────────────────────────────────────────────────────────────────────────────
dist/
build/
.next/
.nuxt/
out/
.cache/
.parcel-cache/
.eslintcache/
.tsbuildinfo
.npm/
.yarn/
.pnpm-store/
coverage/
*.log

# ─────────────────────────────────────────────────────────────────────────────
# 3. Environment Variables & Secrets (CRITICAL for Security)
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
!*.env.example

# TLS / keys — never commit real certificates
*.pem
*.key
*.p12
*.pfx
infra/ssl/*.pem
!infra/ssl/.gitkeep

# ─────────────────────────────────────────────────────────────────────────────
# 4. Large Media, Uploads & Archives
# ─────────────────────────────────────────────────────────────────────────────
# BigBlueButton raw recordings and audio/video files
*.flv
*.mp4
*.wav
*.mp3
*.webm
*.avi
*.mkv
bigbluebutton/record-and-playback/core/resources/raw/

# Moodle data and uploads (if any are stored in the repo path)
moodledata/
moodle/public/uploaddata/

# Project archives / dumps (do not push multi-GB source bundles)
coachingos_core*.zip
*.zip
*.tar.gz
*.tgz
*.rar
*.7z
*.iso
*.dmg

# Generated API audit reports (regenerate locally)
test-report-chunk*.md

# Parquet and large dataset exports (keep sample CSV templates under web/public if needed)
*.parquet
*.tsv
*.sql.gz
*.json.gz
# Bulk data exports only — allow small templates in web/public/samples/
*.csv
!web/public/**/*.csv

# ─────────────────────────────────────────────────────────────────────────────
# 5. Service-Specific Exclusions (third-party platform clones)
# ─────────────────────────────────────────────────────────────────────────────
# Run Moodle, ClickHouse, Metabase, ERPNext, etc. via Docker images — not from git.
/clickhouse/
/moodle/
/metabase/
/superset/
/erpnext/
/bigbluebutton/
/education/
/novu/

# ─────────────────────────────────────────────────────────────────────────────
# 6. IDEs, Editors & System Files
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
.cursor/
*.suo
*.user
*.workspace
*.sublime-project
*.sublime-workspace
