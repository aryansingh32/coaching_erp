# CoachingOS Gateway — local development
# Copy to gateway/.env and adjust values

NODE_ENV=development
PORT=3000

# PostgreSQL (start with: docker compose -f ../infra/docker-compose.yml up -d postgres redis)
DB_HOST=localhost
DB_PORT=5432
DB_USER=coaching
DB_PASS=change_me_strong_db_password
DB_NAME=coaching_db
# Use migrations instead of auto-sync in dev (recommended)
DB_SYNCHRONIZE=false
RUN_MIGRATIONS=true

DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

JWT_SECRET=dev_jwt_secret_change_in_production_32chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production

# Dev OTP — any phone can use this code at login
OTP_DEV_CODE=123456
SUPER_ADMIN_PHONES=9999999999

# ERPNext (required by Joi — use placeholders if ERP not running yet)
ERPNEXT_URL=http://localhost:8000
ERPNEXT_API_KEY=dev
ERPNEXT_API_SECRET=dev
ERPNEXT_DEFAULT_COMPANY=CoachingOS

# Moodle
MOODLE_URL=http://localhost:8080
MOODLE_ADMIN_TOKEN=dev

# BigBlueButton
BBB_URL=https://bbb.example.com/bigbluebutton/api
BBB_SECRET=dev

# Metabase
METABASE_URL=http://localhost:3030
METABASE_SECRET_KEY=dev_metabase_secret_key_32_characters
METABASE_DASHBOARD_ID=1

# Novu
NOVU_APP_ID=

# Razorpay (platform fallback — institutes can override in settings)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=change_me
RAZORPAY_WEBHOOK_SECRET=change_me

# Redis (optional for OTP cache — use in-memory if unavailable)
# REDIS_URL=redis://localhost:6379
