# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  CoachingOS — Environment Configuration Template                            ║
# ║  Copy this file to .env and fill in all values before starting services.    ║
# ║                                                                             ║
# ║  SECURITY: Never commit .env to version control.                            ║
# ║  The .gitignore should include: .env, *.pem, *.key                          ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────────────────
# PLATFORM
# ─────────────────────────────────────────────────────────────────────────────
# Primary domain for the platform. Used for Nginx routing and CORS.
# Use coachingos.local for local development (add to /etc/hosts).
DOMAIN=coachingos.local
PLATFORM_NAME=CoachingOS

# ─────────────────────────────────────────────────────────────────────────────
# GATEWAY POSTGRESQL
# ─────────────────────────────────────────────────────────────────────────────
# Platform-only DB with 6 tables:
#   institutes, rfid_cards, jwt_refresh_tokens, event_outbox,
#   question_bank, test_attempts
DB_PASSWORD=change_me_strong_db_password

# ─────────────────────────────────────────────────────────────────────────────
# PGBOUNCER — Connection Pooling (v3 Flaw G)
# ─────────────────────────────────────────────────────────────────────────────
# Number of actual PostgreSQL connections in the pool.
# 25 is sufficient for most deployments; increase for >100 concurrent users.
PGBOUNCER_POOL_SIZE=25

# ─────────────────────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────────────────────
# Used for: OTP cache, ERPNext read cache, BullMQ queues, Socket.io adapter,
#           payment idempotency keys, test timer keys
REDIS_PASSWORD=change_me_redis_password

# ─────────────────────────────────────────────────────────────────────────────
# JWT — Authentication Tokens
# ─────────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_64_char_random_secret_for_access_tokens
JWT_REFRESH_SECRET=change_me_64_char_random_secret_for_refresh_tokens
# Separate secret for super admin panel (superadmin.coachingos.local)
SUPERADMIN_JWT_SECRET=change_me_separate_64_char_secret_for_superadmin

# ─────────────────────────────────────────────────────────────────────────────
# ERPNEXT + EDUCATION — Master Identity (v2 Issue 1)
# ─────────────────────────────────────────────────────────────────────────────
# ERPNext is THE source of truth for: Student, Guardian, Instructor,
# Student Group (batch), Program, Fee Structure, Payment Entry, etc.
ERPNEXT_DB_ROOT_PASSWORD=change_me_erpnext_root_pass
ERPNEXT_ADMIN_PASSWORD=change_me_erpnext_admin_pass
# API credentials: Settings → API Access → New Key → Role: System Manager
# Leave empty until ERPNext first boot, then generate and fill in.
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# MOODLE — Headless LMS (v2 Issue 2)
# ─────────────────────────────────────────────────────────────────────────────
# Admin token only. NO student credentials are ever stored or used.
# Every Moodle operation is a server-to-server call using this token.
MOODLE_DB_ROOT_PASSWORD=change_me_moodle_root_pass
MOODLE_DB_PASSWORD=change_me_moodle_db_pass
MOODLE_ADMIN_PASSWORD=change_me_moodle_admin_pass
# Generate after Moodle first boot:
#   Site Admin → Web Services → Manage Tokens → Create token for admin
MOODLE_ADMIN_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# BIGBLUEBUTTON — Live Class Engine
# ─────────────────────────────────────────────────────────────────────────────
# BBB runs on a separate Ubuntu 20.04 bare-metal/VM server (NOT in Docker).
# Get the secret with: bbb-conf --secret
BBB_SERVER_DOMAIN=bbb.coachingos.local
BBB_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# CLICKHOUSE — Analytics Engine (v3 Issue 6)
# ─────────────────────────────────────────────────────────────────────────────
CLICKHOUSE_USER=coaching_analytics
CLICKHOUSE_PASSWORD=change_me_clickhouse_pass

# ─────────────────────────────────────────────────────────────────────────────
# METABASE — Embedded BI (v2 Issue 3: single BI system, no Superset)
# ─────────────────────────────────────────────────────────────────────────────
# Used for signed JWT embedding of analytics dashboards in admin panel.
# Generate with: openssl rand -hex 32
METABASE_SECRET_KEY=change_me_64_char_metabase_secret

# ─────────────────────────────────────────────────────────────────────────────
# NOVU — Notification Engine
# ─────────────────────────────────────────────────────────────────────────────
# Multi-channel: WhatsApp (Wati.io), SMS (MSG91), Push (Firebase), Email
# Generate JWT secret and encryption key with: openssl rand -hex 32
NOVU_JWT_SECRET=change_me_64_char_novu_jwt_secret
NOVU_ENCRYPTION_KEY=change_me_32_char_novu_encryption_key
# API key: generated after Novu first boot in the Novu dashboard
NOVU_API_KEY=
# Application identifier shown in Novu dashboard (for web bell widget)
NOVU_APP_ID=

# Metabase dashboard ID for embedded analytics (Settings → Dashboards in Metabase)
METABASE_DASHBOARD_ID=1

# ─────────────────────────────────────────────────────────────────────────────
# MINIO — Object Storage
# ─────────────────────────────────────────────────────────────────────────────
# Stores PDFs, HLS video segments, receipts, watermarked files,
# ClickHouse cold-tier data, bulk import CSVs
MINIO_ACCESS_KEY=change_me_minio_access_key
MINIO_SECRET_KEY=change_me_minio_secret_key

# ─────────────────────────────────────────────────────────────────────────────
# BUNNYCDN — Video Delivery CDN (v3 Flaw D)
# ─────────────────────────────────────────────────────────────────────────────
# Optional — leave empty to serve videos directly from MinIO.
# Recommended for production to reduce latency for tier-3 city students.
BUNNY_CDN_HOSTNAME=cdn.coachingos.local
BUNNY_TOKEN_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# RAZORPAY — Payment Gateway
# ─────────────────────────────────────────────────────────────────────────────
# v3 Issue 8: webhook idempotency protects against duplicate processing.
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=change_me_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=change_me_razorpay_webhook_secret

# ─────────────────────────────────────────────────────────────────────────────
# WHATSAPP — Wati.io Integration
# ─────────────────────────────────────────────────────────────────────────────
WATI_API_URL=https://live-server-xxxxx.wati.io
WATI_TOKEN=change_me_wati_token

# ─────────────────────────────────────────────────────────────────────────────
# SMS — MSG91 Integration
# ─────────────────────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=change_me_msg91_key
MSG91_SENDER_ID=COACHS

# ─────────────────────────────────────────────────────────────────────────────
# FIREBASE — Push Notifications (FCM)
# ─────────────────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=change_me_firebase_private_key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ─────────────────────────────────────────────────────────────────────────────
# RFID SERVICE
# ─────────────────────────────────────────────────────────────────────────────
# Shared secret between rfid-service and gateway for punch authentication.
RFID_SERVICE_TOKEN=change_me_rfid_shared_secret
# HMAC secret for POST /attendance/rfid-punch (gateway verifies X-RFID-Signature)
RFID_WEBHOOK_SECRET=change_me_rfid_webhook_hmac_secret

# ─────────────────────────────────────────────────────────────────────────────
# GATEWAY — CORS & docs
# ─────────────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API (required in production)
CORS_ORIGINS=http://localhost:3001,https://app.coachingos.local
# Set true to expose /api/docs in production (default: dev only)
ENABLE_SWAGGER=false
# Dev OTP bypass for gateway login (docker-compose.dev.yml)
OTP_DEV_CODE=123456
SUPER_ADMIN_PHONES=9999999999

# ─────────────────────────────────────────────────────────────────────────────
# OBSERVABILITY (v2 Issue 7)
# ─────────────────────────────────────────────────────────────────────────────
# Grafana accessible at ops.coachingos.local — internal team only, IP-restricted
GRAFANA_PASSWORD=change_me_grafana_password

# ─────────────────────────────────────────────────────────────────────────────
# BACKUP (v3 Issue 7)
# ─────────────────────────────────────────────────────────────────────────────
# S3-compatible bucket for off-site backup storage.
# Daily backup runs via cron: 0 2 * * * /path/to/infra/scripts/backup-all.sh
BACKUP_S3_BUCKET=s3://your-backup-bucket/coaching-os
AWS_ACCESS_KEY_ID=change_me_backup_aws_key
AWS_SECRET_ACCESS_KEY=change_me_backup_aws_secret

# ─────────────────────────────────────────────────────────────────────────────
# WEB (Next.js) — copy to web/.env.local for production
# ─────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.coachingos.in/api/v1
# NEXT_PUBLIC_METABASE_DASHBOARD_ID=1
# NEXT_PUBLIC_NOVU_APP_ID=your-novu-app-id
